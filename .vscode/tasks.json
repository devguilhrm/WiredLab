{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Compilar",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/Bin/${fileBasenameNoExtension}",
                
                "-I${workspaceFolder}/Include",

                "${workspaceFolder}/Source/DHCP_Starvation.cpp",
                "${workspaceFolder}/Source/Packet.cpp",
                "${workspaceFolder}/Source/Utils.cpp",

                "-lcurl"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "compilador: /usr/bin/g++"
        },
    ]
}